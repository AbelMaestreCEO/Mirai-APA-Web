{
  "name": "mirai-apa-formatter",
  "version": "1.0.0",
  "description": "Formateador automático de documentos a estilo APA 7",
  "author": "Abel Maestre",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev . --compatibility-date=2024-01-01",
    "deploy": "wrangler pages deploy . --project-name=mirai-apa-web",
    "db:init": "wrangler d1 execute mirai-apa-db --file=./schema/init.sql",
    "db:init:local": "wrangler d1 execute mirai-apa-db --local --file=./schema/init.sql"
  },
  "devDependencies": {
    "wrangler": "^3.50.0"
  }
}
